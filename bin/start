#!/usr/bin/env zsh
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
PLIST="${HOME}/Library/LaunchAgents/com.claire.codex-progress-notifier.plist"

mkdir -p "${HOME}/Library/LaunchAgents"
sed "s#__ROOT__#${ROOT//\\/\\\\}#g; s#__HOME__#${HOME//\\/\\\\}#g" \
  "${ROOT}/launchd/com.claire.codex-progress-notifier.plist.template" > "$PLIST"

launchctl bootout "gui/$(id -u)" "$PLIST" >/dev/null 2>&1 || true
launchctl bootstrap "gui/$(id -u)" "$PLIST"
launchctl enable "gui/$(id -u)/com.claire.codex-progress-notifier"

echo "Codex 进度提醒已启动。"
echo "如果没有弹出通知，请到 系统设置 > 通知 允许来自“终端”或“terminal-notifier”的通知。"
echo "如果不能识别 Codex 状态，请到 系统设置 > 隐私与安全性 > 辅助功能 允许当前终端应用。"
