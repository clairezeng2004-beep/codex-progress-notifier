#!/usr/bin/env zsh
set -euo pipefail

export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"

APP_NAME="${CODEX_APP_NAME:-Codex}"
POLL_SECONDS="${CODEX_NOTIFY_POLL_SECONDS:-2}"
COMPLETION_QUIET_SECONDS="${CODEX_NOTIFY_COMPLETION_QUIET_SECONDS:-18}"
SUPPRESS_WHEN_CODEX_VISIBLE="${CODEX_NOTIFY_SUPPRESS_WHEN_VISIBLE:-1}"
APPROVAL_NOTIFICATIONS="${CODEX_NOTIFY_APPROVALS:-0}"
CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
STATE_DB="${CODEX_STATE_DB:-$CODEX_HOME/state_5.sqlite}"
LOGS_DB="${CODEX_LOGS_DB:-$CODEX_HOME/logs_2.sqlite}"
STATE_DIR="${HOME}/Library/Application Support/CodexProgressNotifier"
STATE_FILE="${STATE_DIR}/state"
READ_FILE="${STATE_DIR}/read"
NOTIFIED_FILE="${STATE_DIR}/notified"
LOG_FILE="${STATE_DIR}/notifier.log"
NOTIFICATION_GROUP="codex-progress"
ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
DEFAULT_ICON_FILE="/Applications/Codex.app/Contents/Resources/icon.icns"
if [[ -f "$DEFAULT_ICON_FILE" ]]; then
  ICON_FILE="${CODEX_NOTIFY_ICON:-$DEFAULT_ICON_FILE}"
else
  ICON_FILE="${CODEX_NOTIFY_ICON:-$ROOT_DIR/assets/codex-notification.png}"
fi

mkdir -p "$STATE_DIR"
touch "$STATE_FILE" "$READ_FILE" "$NOTIFIED_FILE" "$LOG_FILE"

log() {
  printf '%s %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*" >> "$LOG_FILE"
}

escape_applescript() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

front_app() {
  osascript <<'APPLESCRIPT' 2>/dev/null || true
tell application "System Events"
  get name of first application process whose frontmost is true
end tell
APPLESCRIPT
}

codex_visible() {
  osascript <<'APPLESCRIPT' 2>/dev/null || true
set appName to "Codex"
tell application "System Events"
  set visibleCount to 0
  try
    set codexProc to first application process whose name is appName
    repeat with w in windows of codexProc
      set isVisible to false
      set isMinimized to false
      try
        set isVisible to visible of w
      end try
      try
        set isMinimized to value of attribute "AXMinimized" of w
      end try
      if isVisible is true and isMinimized is false then
        set visibleCount to visibleCount + 1
      end if
    end repeat
  end try
end tell

if visibleCount > 0 then
  return "yes"
else
  return "no"
end if
APPLESCRIPT
}

remove_notification() {
  if command -v terminal-notifier >/dev/null 2>&1; then
    terminal-notifier -remove "$NOTIFICATION_GROUP" >/dev/null 2>&1 || true
  fi
}

notify() {
  local title="$1"
  local message="$2"

  if command -v terminal-notifier >/dev/null 2>&1; then
    terminal-notifier \
      -title "$title" \
      -message "$message" \
      -group "$NOTIFICATION_GROUP" \
      -appIcon "$ICON_FILE" \
      -execute "open -a ${APP_NAME}" \
      -sound default >/dev/null 2>&1 || true
  else
    local safe_title safe_message
    safe_title="$(escape_applescript "$title")"
    safe_message="$(escape_applescript "$message")"
    osascript -e "display notification \"${safe_message}\" with title \"${safe_title}\" sound name \"Glass\"" >/dev/null 2>&1 || true
  fi
}

latest_thread_snapshot() {
  if [[ ! -f "$STATE_DB" ]]; then
    printf 'missing_db||0|找不到 Codex 本地状态数据库。'
    return
  fi

  sqlite3 -readonly "$STATE_DB" \
    "select id || char(31) || replace(replace(coalesce(nullif(title,''),'Codex 对话'), char(10), ' '), char(13), ' ') || char(31) || coalesce(updated_at_ms, updated_at * 1000, 0) || char(31) || replace(replace(coalesce(nullif(preview,''), first_user_message, ''), char(10), ' '), char(13), ' ') from threads where archived = 0 order by coalesce(updated_at_ms, updated_at * 1000, 0) desc limit 1;" \
    2>/dev/null || true
}

latest_approval_id() {
  local thread_id="$1"
  if [[ "$APPROVAL_NOTIFICATIONS" != "1" ]]; then
    return
  fi
  if [[ ! -f "$LOGS_DB" ]]; then
    return
  fi

  sqlite3 -readonly "$LOGS_DB" \
    "select coalesce(max(id),'') from logs where thread_id = '$thread_id' and ts >= strftime('%s','now') - 120 and target = 'codex_api::endpoint::responses_websocket' and feedback_log_body like '%request_permissions call%' and feedback_log_body not like '%approval assessment%' and feedback_log_body not like '%TRANSCRIPT%';" \
    2>/dev/null || true
}

latest_assistant_message_id() {
  local thread_id="$1"
  if [[ ! -f "$LOGS_DB" ]]; then
    return
  fi

  sqlite3 -readonly "$LOGS_DB" \
    "select coalesce(max(id),'') from logs where thread_id = '$thread_id' and ts >= strftime('%s','now') - 300 and feedback_log_body like '%op.dispatch.assistant_message%';" \
    2>/dev/null || true
}

trim_chars() {
  local limit="$1"
  local value="$2"
  value="$(printf '%s' "$value" | tr '\n\t' '  ' | sed 's/[[:space:]][[:space:]]*/ /g; s/^ //; s/ $//')"
  LIMIT="$limit" perl -CS -Mutf8 -ne 'chomp; $limit=$ENV{LIMIT}; print length($_) > $limit ? substr($_, 0, $limit) . "..." : $_' <<< "$value"
}

now_ms() {
  printf '%s000' "$(date +%s)"
}

log "started database mode"

while true; do
  front="$(front_app)"
  visible="$(codex_visible)"
  codex_is_seen="0"
  if [[ "$front" == "$APP_NAME" || ("$SUPPRESS_WHEN_CODEX_VISIBLE" == "1" && "$visible" == "yes") ]]; then
    codex_is_seen="1"
  fi

  if [[ "$codex_is_seen" == "1" ]]; then
    remove_notification
  fi

  raw="$(latest_thread_snapshot)"
  thread_id="$(printf '%s' "$raw" | awk -F $'\037' '{print $1}')"
  thread_title="$(printf '%s' "$raw" | awk -F $'\037' '{print $2}')"
  updated_at_ms="$(printf '%s' "$raw" | awk -F $'\037' '{print $3}')"
  preview="$(printf '%s' "$raw" | awk -F $'\037' '{print $4}')"

  summary="$(trim_chars 34 "${thread_title:-Codex 对话}")"
  preview_summary="$(trim_chars 20 "${preview:-}")"
  if [[ -n "$preview_summary" && "$preview_summary" != "$summary" ]]; then
    summary="${summary} - ${preview_summary}"
  fi

  read_state="$(cat "$READ_FILE" 2>/dev/null || true)"
  last_notified="$(cat "$NOTIFIED_FILE" 2>/dev/null || true)"
  current_state="${thread_id}|${updated_at_ms}"

  if [[ "$codex_is_seen" == "1" && -n "$thread_id" && "$thread_id" != "missing_db" ]]; then
    printf '%s' "$current_state" > "$READ_FILE"
    read_state="$current_state"
  fi

  if [[ "$codex_is_seen" != "1" && -n "$thread_id" && "$thread_id" != "missing_db" && "$current_state" != "$read_state" ]]; then
    approval_id="$(latest_approval_id "$thread_id")"
    if [[ -n "$approval_id" && "${thread_id}|approval|${approval_id}" != "$last_notified" ]]; then
      notify "Codex 需要授权" "$summary"
      log "notified approval: ${summary}"
      printf '%s' "${thread_id}|approval|${approval_id}" > "$NOTIFIED_FILE"
    else
      assistant_id="$(latest_assistant_message_id "$thread_id")"
      quiet_ms=$(( COMPLETION_QUIET_SECONDS * 1000 ))
      age_ms=$(( $(now_ms) - ${updated_at_ms:-0} ))
      if [[ -n "$assistant_id" && "$age_ms" -ge "$quiet_ms" && "${thread_id}|complete|${updated_at_ms}" != "$last_notified" ]]; then
        notify "Codex 任务完成" "$summary"
        log "notified completion: ${summary}"
        printf '%s' "${thread_id}|complete|${updated_at_ms}" > "$NOTIFIED_FILE"
      fi
    fi
  fi

  printf '%s' "$current_state" > "$STATE_FILE"
  sleep "$POLL_SECONDS"
done
